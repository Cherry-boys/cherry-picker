{
  "name": "cherrypick",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "docs:list": "bun run ./scripts/docs-list.ts",
    "db:generate": "bun run --filter @repo/db db:generate",
    "db:migrate": "bun run --filter @repo/db db:migrate",
    "db:deploy": "bun run --filter @repo/db db:deploy",
    "db:studio": "bun run --filter @repo/db db:studio",
    "db:seed": "bun run --filter @repo/db db:seed",
    "ares:build": "make -C tools/ares build",
    "ares:install": "make -C tools/ares install",
    "ares:test": "make -C tools/ares test"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.17",
    "@types/bun": "^1.3.13",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@repo/db": "*",
    "@langchain/anthropic": "^1.3.27",
    "@langchain/core": "^1.1.41",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/tavily": "^1.2.0",
    "deepagents": "^1.9.0",
    "langchain": "^1.3.4",
    "zod": "^4.3.6"
  }
}
