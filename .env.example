# Database connection — copy this file to .env and pick one target below.
# DATABASE_URL is used at runtime; DIRECT_URL is used by Prisma migrations.

# Local Docker (default) — `docker compose up -d`
DATABASE_URL="postgresql://cherrypick:dev@localhost:5432/cherrypick"
DIRECT_URL="postgresql://cherrypick:dev@localhost:5432/cherrypick"

# Shared Neon (uncomment to use the team database)
# DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
# DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require"
